{
  "name": "block-pr-by-label-action",
  "version": "1.0.0",
  "description": "GitHub Action to block PRs from merging if they carry specific labels",
  "main": "dist/index.js",
  "license":"MIT",
  "author": {
    "name": "Carlos Menezes",
    "url": "https://carlos-menezes.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/carlos-menezes/block-pr-by-label-action"
  },
  "scripts": {
    "build": "rolldown -c",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "biome format --write",
      "biome check"
    ]
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "rolldown": "1.0.0-rc.10",
    "typescript": "^5.8.2"
  }
}
